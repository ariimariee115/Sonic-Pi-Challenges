# ---------------- NOTES ---------------- #
#2 arrays go here one for sleeps one for notes

define :second_notes do
  play :a4
  sleep 0.75
  play :fs4
  sleep 0.75
  play :e4
  sleep 0.5
  play :a4
  sleep 0.5
end
#14.5 sleep time including first and second notes

#----------- music starts here ---------------- #
live_loop :continue do
  sample background
  sleep sample_duration(background)
  stop
end

in_thread do
  sleep 16.3 #plays before sample background comes to a complete end
  use_synth :hollow
  with_fx :mono do
    #first_notes
    12.times do
      play notes[i]
      sleep(sleepy[s])
      i = i + 1
      s = s + 1
    end
    second_notes
  end
  
  sample aahs
  
  sleep 0.02
  
  sample vocals
  print sample_duration(vocals)
  
  sleep 65
  
  use_synth :hollow
  second_notes
  
  sleep 10
  
  use_synth :hollow
  second_notes
  
  sleep sample_duration(vocals)
  sample girl
  
  sleep sample_duration(girl)
  sample fading
  
  # ---------------- FADE OUT INTRO ---------------- #
  #sample intro, fade out = load samples into an array and decrease the amp (using a variable) each time you loop
  
  3.times do
    sample intro, amp: a
    sleep 11
    a = a - 0.5
  end
  
end


